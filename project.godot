; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RunAndShooter"
run/main_scene="uid://bx3jhbb7onn8d"
config/features=PackedStringArray("4.6")
config/icon="uid://bsicdi7nootak"

[autoload]

GameManager="*uid://xo8cdkuno1y8"
AudioManager="*uid://cp3m20235tdg8"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Scene/": "orange",
"res://Scene/Cena/": "green",
"res://Util/": "yellow"
}

[global_group]

tiro_do_player="O tiro do player"
inimigos="Grupo do inimigos"
players="Grupo dos players"
upgrade_coletavel=""
inimigo_tiro=""
camera="grupo da camera"

